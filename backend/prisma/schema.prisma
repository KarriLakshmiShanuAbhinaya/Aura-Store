generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  SELLER
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  phone      String
  password   String
  role       Role      @default(CUSTOMER)
  otp        String?
  isVerified Boolean   @default(false)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  images      String[]
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  sellerId    String?
  seller      User?    @relation(fields: [sellerId], references: [id])
  inStock     Boolean  @default(true)
  stockCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  total     Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
